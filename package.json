{
  "name": "neuroshow",
  "version": "1.0.0",
  "description": "AI Show Engine - automated talk shows with AI characters",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc -p web/debug-ui/tsconfig.json",
    "build:ui": "tsc -p web/debug-ui/tsconfig.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/debug-ui/tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "kill": "lsof -ti:3000 | xargs kill -9 2>/dev/null; echo 'Port 3000 freed'",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e-openai": "vitest run tests/integration/full-show-openai.test.ts",
    "test:e2e": "playwright test",
    "lint": "eslint src/ tests/ web/"
  },
  "keywords": [
    "ai",
    "show",
    "llm",
    "characters"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "openai": "^4.77.0",
    "tiktoken": "^1.0.22",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "serve": "^14.2.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
