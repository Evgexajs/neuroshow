# LLM Provider
ADAPTER_MODE=mock           # mock | openai

# OpenAI (required when ADAPTER_MODE=openai)
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4.1-mini

# Token Budget
TOKEN_BUDGET_PER_SHOW=500000

# Server
PORT=3000

# Database
DB_PATH=./data/neuroshow.db

# Environment
NODE_ENV=development
